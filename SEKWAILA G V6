# HTF ALIGNMENT CHECK
# ============================================================

def check_htf_alignment(df):
    close = df['Close']
    current_price = close.iloc[-1]
    
    ema50_daily = close.tail(50).mean()
    ema200_daily = close.tail(200).mean() if len(close) > 200 else close.mean()
    ema20_4h = close.tail(16).mean()
    ema50_4h = close.tail(50).mean()
    
    daily_trend = "Bullish" if current_price > ema50_daily > ema200_daily else "Bearish" if current_price < ema50_daily < ema200_daily else "Neutral"
    h4_trend = "Bullish" if current_price > ema20_4h > ema50_4h else "Bearish" if current_price < ema20_4h < ema50_4h else "Neutral"
    
    return {"daily_trend": daily_trend, "h4_trend": h4_trend}

# ============================================================
# PRECISION TAKE PROFIT CALCULATOR
# ============================================================

def calculate_precision_tps(price, atr, signal_type, pair_name):
    
    atr_adj = atr * 0.5 if pair_name in ["USTECH", "US30"] else atr
    
    if signal_type == "BUY":
        return round(price + atr_adj * 0.2, 2), round(price + atr_adj * 0.35, 2), round(price + atr_adj * 0.55, 2), round(price - atr_adj * 0.5, 2)
    elif signal_type == "STRONG BUY":
        return round(price + atr_adj * 0.7, 2), round(price + atr_adj * 1.8, 2), round(price + atr_adj * 2.2, 2), round(price - atr_adj * 1.0, 2)
    elif signal_type == "EXTREME BUY":
        return round(price + atr_adj * 0.35, 2), round(price + atr_adj * 2.0, 2), round(price + atr_adj * 3.0, 2), round(price - atr_adj * 1.5, 2)
    elif signal_type == "SELL":
        return round(price - atr_adj * 0.2, 2), round(price - atr_adj * 0.35, 2), round(price - atr_adj * 0.55, 2), round(price + atr_adj * 0.5, 2)
    elif signal_type == "STRONG SELL":
        return round(price - atr_adj * 0.7, 2), round(price - atr_adj * 1.8, 2), round(price - atr_adj * 2.2, 2), round(price + atr_adj * 1.0, 2)
    elif signal_type == "EXTREME SELL":
        return round(price - atr_adj * 0.35, 2), round(price - atr_adj * 2.0, 2), round(price - atr_adj * 3.0, 2), round(price + atr_adj * 1.5, 2)
    else:
        return price, price, price, price

