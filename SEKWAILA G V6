def detect_order_blocks(df, lookback=20):
    high = df['High']
    low = df['Low']
    close = df['Close']
    
    bullish_obs = 0
    bearish_obs = 0
    
    for i in range(lookback, len(df) - 1):
        if close.iloc[i] > close.iloc[i-1] and close.iloc[i-2] < close.iloc[i-3]:
            bullish_obs += 1
        if close.iloc[i] < close.iloc[i-1] and close.iloc[i-2] > close.iloc[i-3]:
            bearish_obs += 1
    
    return bullish_obs, bearish_obs

def detect_choch(df, lookback=30):
    high = df['High']
    low = df['Low']
    
    bullish_choch = 0
    bearish_choch = 0
    
    for i in range(lookback, len(df) - 5):
        if high.iloc[i] > high.iloc[i-1] and high.iloc[i] > high.iloc[i+1]:
            if high.iloc[i] > high.iloc[i-5:i].max():
                bullish_choch += 1
        if low.iloc[i] < low.iloc[i-1] and low.iloc[i] < low.iloc[i+1]:
            if low.iloc[i] < low.iloc[i-5:i].min():
                bearish_choch += 1
    
    return bullish_choch, bearish_choch

def detect_supply_demand(df, lookback=20):
    high = df['High']
    low = df['Low']
    close = df['Close']
    
    supply_zones = 0
    demand_zones = 0
    
    for i in range(lookback, len(df) - 5):
        if close.iloc[i] > close.iloc[i-1] and close.iloc[i+3] < close.iloc[i]:
            supply_zones += 1
        if close.iloc[i] < close.iloc[i-1] and close.iloc[i+3] > close.iloc[i]:
            demand_zones += 1
    
    return supply_zones, demand_zones

def analyze_volume(df):
    volume = df['Volume']
    close = df['Close']
    
    if volume.empty or volume.sum() == 0:
        return 0, 0
    
    avg_volume = volume.tail(20).mean()
    current_volume = volume.iloc[-1]
    volume_surge = current_volume > (avg_volume * 1.5)
    price_up = close.iloc[-1] > close.iloc[-5:].mean()
    
    if price_up and volume_surge:
        return 1, volume_surge
    elif not price_up and volume_surge:
        return -1, volume_surge
    else:
        return 0, volume_surge

def detect_fvg(df, lookback=20):
    high = df['High']
    low = df['Low']
    
    fvg_bullish = 0
    fvg_bearish = 0
    
    for i in range(lookback, len(df) - 2):
        if low.iloc[i] > high.iloc[i-1]:
            fvg_bullish += 1
        if high.iloc[i] < low.iloc[i-1]:
            fvg_bearish += 1
    
    return fvg_bullish, fvg_bearish

def detect_liquidity_levels(df, lookback=30):
    high = df['High']
    low = df['Low']
    
    swing_highs = []
    swing_lows = []
    
    for i in range(5, len(high) - 1):
        if high.iloc[i] > high.iloc[i-1] and high.iloc[i] > high.iloc[i+1]:
            swing_highs.append(high.iloc[i])
    
    for i in range(5, len(low) - 1):
        if low.iloc[i] < low.iloc[i-1] and low.iloc[i] < low.iloc[i+1]:
            swing_lows.append(low.iloc[i])
    
    current_price = high.iloc[-1]
    
    sell_liq = 0
    buy_liq = 0
    
    for sh in swing_highs[-5:]:
        if current_price > sh:
            sell_liq += 1
    for sl in swing_lows[-5:]:
        if current_price < sl:
            buy_liq += 1
    
    return sell_liq, buy_liq

