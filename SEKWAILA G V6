def analyze_pair(df, pair_name, dxy_strength):

    close = df['Close']
    current_price = float(close.iloc[-1])

    # VISIBLE INDICATORS
    ema20 = close.ewm(span=20).mean()
    ema50 = close.ewm(span=50).mean()
    ema200 = close.ewm(span=200).mean()
    rsi = calculate_rsi(close)
    current_rsi = float(rsi.iloc[-1])
    atr = (df['High'] - df['Low']).rolling(14).mean().iloc[-1]

    # HIDDEN ENGINE
    bullish_obs, bearish_obs = detect_order_blocks(df)
    ob_score = bullish_obs - bearish_obs
    bullish_choch, bearish_choch = detect_choch(df)
    choch_score = bullish_choch - bearish_choch
    supply_zones, demand_zones = detect_supply_demand(df)
    sd_score = demand_zones - supply_zones
    volume_score, volume_surge = analyze_volume(df)
    fvg_bullish, fvg_bearish = detect_fvg(df)
    fvg_score = fvg_bullish - fvg_bearish
    sell_liq, buy_liq = detect_liquidity_levels(df)
    liquidity_score = buy_liq - sell_liq
    
    hidden_score = (ob_score * 0.15 + choch_score * 0.20 + sd_score * 0.15 + 
                    volume_score * 0.25 + fvg_score * 0.10 + liquidity_score * 0.15)
    hidden_score = max(-20, min(20, hidden_score * 2))

    # SCORING
    score = 50
    
    if current_price > ema20.iloc[-1]: score += 5
    else: score -= 5
    if current_price > ema50.iloc[-1]: score += 10
    else: score -= 10
    if current_price > ema200.iloc[-1]: score += 20
    else: score -= 20
    
    if current_rsi > 60: score += 15
    elif current_rsi < 40: score -= 15
    
    recent_high = df['High'].tail(20).max()
    recent_low = df['Low'].tail(20).min()
    if current_price >= recent_high * 0.998: score += 10
    if current_price <= recent_low * 1.002: score -= 10
    
    if pair_name in ["XAUUSD", "EURUSD", "GBPUSD", "USTECH", "US30"]:
        if dxy_strength > 70: score -= 20
        elif dxy_strength < 30: score += 20
    if pair_name == "USDJPY":
        if dxy_strength > 70: score += 20
        elif dxy_strength < 30: score -= 20
    
    score += hidden_score
    score = max(0, min(100, score))

    # HTF ALIGNMENT
    htf = check_htf_alignment(df)
    
    # SIGNAL DETERMINATION
    if score >= 90:
        signal, css, state, signal_type = "EXTREME BUY", "extreme-buy", "🚀 AGGRESSIVE ENTRY", "EXTREME BUY"
        tp_label, tp_color = "🔥 EXTREME GAINS", "tp-extreme"
    elif score >= 75:
        signal, css, state, signal_type = "STRONG BUY", "strong-buy", "📈 BREAKTHROUGH", "STRONG BUY"
        tp_label, tp_color = "⚡ MEDIUM GAINS", "tp-medium"
    elif score >= 60:
        signal, css, state, signal_type = "BUY", "buy", "🟡 SIGNAL FORMING", "BUY"
        tp_label, tp_color = "🛡️ SAFE GAINS", "tp-safe"
    elif score <= 10:
        signal, css, state, signal_type = "EXTREME SELL", "extreme-sell", "🚀 AGGRESSIVE ENTRY", "EXTREME SELL"
        tp_label, tp_color = "🔥 EXTREME GAINS", "tp-extreme"
    elif score <= 25:
        signal, css, state, signal_type = "STRONG SELL", "strong-sell", "📉 BREAKTHROUGH", "STRONG SELL"
        tp_label, tp_color = "⚡ MEDIUM GAINS", "tp-medium"
    elif score <= 40:
        signal, css, state, signal_type = "SELL", "sell", "🟠 SIGNAL FORMING", "SELL"
        tp_label, tp_color = "🛡️ SAFE GAINS", "tp-safe"
    else:
        signal, css, state, signal_type = "NEUTRAL", "forming", "⏳ WAIT", "NEUTRAL"
        tp_label, tp_color = "⏳ NO SIGNAL", "forming"

    # TP CALCULATION
    tp1, tp2, tp3, sl = calculate_precision_tps(current_price, atr, signal_type, pair_name)
    
    # HTF ALIGNMENT CHECK
    if "BUY" in signal_type and htf["daily_trend"] == "Bullish" and htf["h4_trend"] == "Bullish":
        htf_aligned = True
    elif "SELL" in signal_type and htf["daily_trend"] == "Bearish" and htf["h4_trend"] == "Bearish":
        htf_aligned = True
    elif signal_type == "NEUTRAL":
        htf_aligned = True
    else:
        htf_aligned = False

    return {
        "signal": signal, "css": css, "state": state, "signal_type": signal_type,
        "confidence": min(max(score, 1), 99), "price": round(current_price, 2),
        "tp1": tp1, "tp2": tp2, "tp3": tp3, "sl": sl,
        "rsi": round(current_rsi, 1), "tp_label": tp_label, "tp_color": tp_color,
        "atr": round(atr, 2), "htf": htf, "htf_aligned": htf_aligned
    }

